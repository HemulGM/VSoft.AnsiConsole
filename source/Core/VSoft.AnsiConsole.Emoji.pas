  TEmoji = record
    { Returns the unicode glyph for `shortName` (case-insensitive) or
      empty string if the shortcode is unknown. }
    class function Get(const shortName : string) : string; static;

    { Scans `text` for ":identifier:" patterns and substitutes each with
      the corresponding glyph. Unknown shortcodes pass through unchanged
      (still bracketed by colons). }
    class function Replace(const text : string) : string; static;

    { Override or add a shortcode mapping. Useful for picking your own
      glyphs for shortcodes that conflict or aren't in the table. }
    class procedure Remap(const shortName, glyph : string); static;
  end;

