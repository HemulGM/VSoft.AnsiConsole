class function TEmoji.Get(const shortName : string) : string;
var
  trimmed : string;
begin
  trimmed := shortName;
  if (Length(trimmed) >= 2)
     and (trimmed[1] = ':') and (trimmed[Length(trimmed)] = ':') then
    trimmed := Copy(trimmed, 2, Length(trimmed) - 2);
  if not GLookup.TryGetValue(LowerCase(trimmed), result) then
    result := '';
end;

class function TEmoji.Replace(const text : string) : string;
var
  i, n : Integer;
  startCol, endCol : Integer;
  shortName, glyph : string;
  sb : TStringBuilder;
begin
  if Pos(':', text) = 0 then
  begin
    result := text;
    Exit;
  end;
  sb := TStringBuilder.Create(Length(text));
  try
    i := 1;
    n := Length(text);
    while i <= n do
    begin
      if text[i] = ':' then
      begin
        // Find matching closing colon. Identifier chars are [a-zA-Z0-9_+-].
        startCol := i;
        endCol := -1;
        i := i + 1;
        while i <= n do
        begin
          if text[i] = ':' then
          begin
            endCol := i;
            Break;
          end;
          if not CharInSet(text[i], ['a'..'z', 'A'..'Z', '0'..'9', '_', '+', '-']) then
            Break;
          i := i + 1;
        end;
        if (endCol > startCol + 1) then
        begin
          shortName := Copy(text, startCol + 1, endCol - startCol - 1);
          if GLookup.TryGetValue(LowerCase(shortName), glyph) then
          begin
            sb.Append(glyph);
            i := endCol + 1;
            Continue;
          end;
        end;
        // Not a recognised shortcode - emit the colon and resume scanning
        // from the next char (which may itself open a new shortcode).
        sb.Append(':');
        i := startCol + 1;
      end
      else
      begin
        sb.Append(text[i]);
        i := i + 1;
      end;
    end;
    result := sb.ToString;
  finally
    sb.Free;
  end;
end;

class procedure TEmoji.Remap(const shortName, glyph : string);
begin
  GLookup.AddOrSetValue(LowerCase(shortName), glyph);
end;

initialization
  GLookup := TDictionary<string, string>.Create;
  RegisterAll;

finalization
  GLookup.Free;

end.
